{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": { "quoteStyle": "double", "semicolons": "asNeeded" }
  },
  "css": {
    "parser": { "tailwindDirectives": true },
    "linter": { "enabled": true },
    "formatter": { "enabled": true }
  },
  "files": {
    "ignoreUnknown": false,
    "includes": ["**", "!**/routeTree.gen.ts", "!**/.wrangler", "!**/dist"]
  },
  "overrides": [
    {
      "includes": ["**/apps/frontend/src/routes/__root.tsx"],
      "linter": {
        "rules": {
          "security": { "noDangerouslySetInnerHtml": "off" }
        }
      }
    },
    {
      "includes": ["**/apps/frontend/src/styles.css"],
      "linter": {
        "rules": {
          "suspicious": { "noShorthandPropertyOverrides": "off" }
        }
      }
    }
  ]
}
