{
  "formatter": {
    "external": {
      "command": "biome",
      "arguments": ["format", "--write", "--stdin-file-path", "{buffer_path}"]
    }
  },
  "format_on_save": "on",
  "languages": {
    "TypeScript": {
      "formatter": { "language_server": { "name": "biome" } }
    },
    "TSX": {
      "formatter": { "language_server": { "name": "biome" } }
    },
    "JavaScript": {
      "formatter": { "language_server": { "name": "biome" } }
    }
  }
}
