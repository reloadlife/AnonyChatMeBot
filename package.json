{
  "name": "anonychatmebot",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev dev:bot",
    "dev:backend": "turbo run dev --filter=@anonychatmebot/backend",
    "dev:bot": "turbo run dev:bot --filter=@anonychatmebot/backend",
    "dev:frontend": "turbo run dev --filter=@anonychatmebot/frontend",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "husky",
    "db:generate": "turbo run db:generate --filter=@anonychatmebot/backend",
    "db:migrate": "turbo run db:migrate --filter=@anonychatmebot/backend",
    "db:migrate:prod": "turbo run db:migrate:prod --filter=@anonychatmebot/backend",
    "db:studio": "turbo run db:studio --filter=@anonychatmebot/backend"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "husky": "^9.1.7",
    "turbo": "^2.3.0",
    "typescript": "^6.0.2"
  }
}
